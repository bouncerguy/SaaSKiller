# =============================================================================
# SaaS Killer — Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/saaskiller

# Alternative: individual PostgreSQL connection parameters
# PGHOST=localhost
# PGPORT=5432
# PGUSER=your_db_user
# PGPASSWORD=your_db_password
# PGDATABASE=saaskiller

# -----------------------------------------------------------------------------
# Authentication (required)
# -----------------------------------------------------------------------------

# Secret for signing session cookies (generate a random string)
SESSION_SECRET=your-random-session-secret-here

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Server port (default: 5000 for Replit; use 3001 on macOS to avoid AirPlay conflict)
# PORT=5000

# Server host (default: 0.0.0.0)
# HOST=0.0.0.0

# Set to "production" for production builds (disables dev seed data)
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Email / SMTP (optional — emails queue in DB if not configured)
# -----------------------------------------------------------------------------

# SMTP server hostname (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.example.com

# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username
SMTP_USER=your_smtp_user

# SMTP authentication password or app-specific password
SMTP_PASSWORD=your_smtp_password

# "From" address for outbound emails
SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# AI Agents (optional — returns "not configured" message if missing)
# -----------------------------------------------------------------------------

# OpenAI API key for AI agent execution (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Backups (optional)
# -----------------------------------------------------------------------------

# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=...
# BACKUP_S3_SECRET_KEY=...
