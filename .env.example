# =============================================================================
# Calendar Core — Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/calendar_core

# Alternative: individual PostgreSQL connection parameters
# PGHOST=localhost
# PGPORT=5432
# PGUSER=your_db_user
# PGPASSWORD=your_db_password
# PGDATABASE=calendar_core

# -----------------------------------------------------------------------------
# Authentication (required)
# -----------------------------------------------------------------------------

# Secret for signing session cookies (generate a random string)
SESSION_SECRET=your-random-session-secret-here

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Set to "production" for production builds (disables dev seed data)
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Future Modules (not yet implemented)
# -----------------------------------------------------------------------------

# Email / SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=noreply@example.com

# AI Agents
# OPENAI_API_KEY=sk-...

# Backups
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=...
# BACKUP_S3_SECRET_KEY=...
